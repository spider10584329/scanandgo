# ===========================================
# SCANANDGO - ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env.local and update with your actual values

# ===========================================
# ENVIRONMENT
# ===========================================
NODE_ENV="production"

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# MariaDB/MySQL Database Connection
DATABASE_URL="mysql://root@localhost:3306/scanandgo_prod"

# ===========================================
# EXTERNAL API CONFIGURATION
# ===========================================
# PulsePoint API Configuration (for admin authentication)
# IMPORTANT: Use https://api.pulsepoint.clinotag.com (NOT myrfid.nc)
PULSEPOINT_API_URL="https://api.pulsepoint.clinotag.com"
PULSEPOINT_API_TIMEOUT="10000"

# ===========================================
# JWT CONFIGURATION
# ===========================================
# Generate a secure secret key for production
# You can generate one using: openssl rand -base64 32
NEXTAUTH_SECRET="qMNz0XN8Mv3iThVE0q2lBL3VviFPydWaSD/oNgpxcZg="

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
# Session configuration (in seconds)
SESSION_MAX_AGE="43200"  # 12 hours

# Password hashing rounds
BCRYPT_ROUNDS="12"
